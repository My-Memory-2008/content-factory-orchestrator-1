  <!-- FAQ -->
  <section class="section-faq" id="faq" aria-labelledby="faq-video-heading">
    <div class="container">
      <div class="section-header">
        <h2 id="faq-video-heading">Frequently Asked Questions</h2>
        <p>Quick answers to the most common questions about saving Instagram videos.</p>
      </div>
     <ul class="faq-list" role="list" aria-label="Frequently asked questions about Instagram video saver">

        <li class="faq-item" role="listitem">
          <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-video-new0" id="faq-video-qnew0">
            <span>How to download a video from Instagram?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer" id="faq-video-new0" role="region" aria-labelledby="faq-video-qnew0" data-speakable="true">
            <p>Open Instagram, find the video post, tap the three-dot menu and select Copy Link. Then return to DownReels and paste the link — it works in Chrome, Safari, Firefox and Edge on any device. The MP4 file saves to your device in seconds. On iPhone it saves to the Files app first; on Android and PC it goes straight to your Downloads folder.</p>
          </div>
        </li>

        <li class="faq-item" role="listitem">
          <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-video-new1" id="faq-video-qnew1">
            <span>Can you save a video from Instagram for offline viewing?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer" id="faq-video-new1" role="region" aria-labelledby="faq-video-qnew1" data-speakable="true">
            <p>Yes — Instagram has no native save-to-device button, so DownReels lets you keep a personal offline copy of any public Instagram video on your phone or computer in MP4 format. Only public accounts are supported — private profiles cannot be accessed.</p>
          </div>
        </li>

        <li class="faq-item" role="listitem">
          <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-video-0" id="faq-video-q0">
            <span>Will the saved Instagram video keep its original quality?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer" id="faq-video-0" role="region" aria-labelledby="faq-video-q0" data-speakable="true">
            <p>Yes. The file you save through DownReels keeps the original quality of the public post — the same resolution and format shown on Instagram, with no extra re-encoding applied by DownReels.</p>
          </div>
        </li>

        <li class="faq-item" role="listitem">
          <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-video-1" id="faq-video-q1">
            <span>Does the saved Instagram video include sound?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer" id="faq-video-1" role="region" aria-labelledby="faq-video-q1" data-speakable="true">
            <p>Yes — every video saved through DownReels includes the original audio track. The MP4 file contains both video and audio exactly as the public post had them. If the original post had sound, your saved file will too.</p>
          </div>
        </li>

        <li class="faq-item" role="listitem">
          <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-video-2" id="faq-video-q2">
            <span>Is it free to use?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer" id="faq-video-2" role="region" aria-labelledby="faq-video-q2" data-speakable="true">
            <p>Yes, completely free. No payment, no subscription, no account, and no credit card — ever. There are no daily limits or hidden caps of any kind.</p>
          </div>
        </li>

        <li class="faq-item" role="listitem">
          <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-video-3" id="faq-video-q3">
            <span>What happens if I paste a private Instagram account link?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer" id="faq-video-3" role="region" aria-labelledby="faq-video-q3" data-speakable="true">
            <p>It will not work. Private Instagram accounts are protected at the server level and cannot be accessed by any third-party tool. Only public posts are supported. If the account is private, ask the creator directly or use Instagram's in-app save feature.</p>
          </div>
        </li>

        <li class="faq-item" role="listitem">
          <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-video-4" id="faq-video-q4">
            <span>Where are saved Instagram videos stored — iPhone, Android &amp; PC?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer" id="faq-video-4" role="region" aria-labelledby="faq-video-q4" data-speakable="true">
            <p>Videos save to your device's default Downloads folder automatically. On Android and PC/Mac they go straight to Downloads. On iPhone they save to the Files app — from there you can move them to your Photos library or share them anywhere.</p>
          </div>
        </li>

        <li class="faq-item" role="listitem">
          <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-video-5" id="faq-video-q5">
            <span>Is DownReels safe to use?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer" id="faq-video-5" role="region" aria-labelledby="faq-video-q5" data-speakable="true">
            <p>Yes. DownReels requires no login, stores no user data, and runs entirely over HTTPS. Only the public post URL is used — to process your request and nothing else. Full privacy details are covered in the <a href="#safe-and-private-video-downloader" style="color:var(--pink);font-weight:600;">Safe &amp; Private section above</a>.</p>
          </div>
        </li>

        <li class="faq-item" role="listitem">
          <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-video-6" id="faq-video-q6">
            <span>Why is my Instagram video save not working?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer" id="faq-video-6" role="region" aria-labelledby="faq-video-q6" data-speakable="true">
            <p>The most common reason is a private account — DownReels can only access public Instagram videos. Other causes include a broken or incomplete link, a post that has been deleted, or a temporary Instagram server issue. Check that the account is public, copy the link again directly from Instagram, and try once more. If the problem continues, refreshing the page or switching browsers usually resolves it.</p>
          </div>
        </li>

        <li class="faq-item" role="listitem">
          <button class="faq-question" type="button" aria-expanded="false" aria-controls="faq-video-7" id="faq-video-q7">
            <span>Is it legal to save Instagram videos?</span>
            <svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="faq-answer" id="faq-video-7" role="region" aria-labelledby="faq-video-q7" data-speakable="true">
            <p>Saving public Instagram content for personal, offline use may be permitted depending on your local laws. Redistributing, republishing, or using someone else's content commercially without the creator's permission is not — copyright always stays with the original creator. DownReels is intended for personal use only.</p>
          </div>
        </li>

      </ul>
    </div>
  </section>

</main>


<style>
.section-other-tools{padding:72px 0;background:linear-gradient(135deg,#fdf0ff 0%,#fff0f5 100%)}
.other-tools-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:20px;max-width:1200px;margin:0 auto;list-style:none;padding:0}
.other-tool-card{background:#fff;border-radius:20px;padding:28px 22px;display:flex;flex-direction:column;gap:12px;border:1.5px solid #f0ddf8;box-shadow:0 4px 20px rgba(225,48,108,.06);transition:transform .22s ease,box-shadow .22s ease}
.other-tool-card:hover{transform:translateY(-4px);box-shadow:0 10px 32px rgba(225,48,108,.12)}
.other-tool-icon{width:52px;height:52px;background:linear-gradient(135deg,#fdf0ff,#fff0f5);border-radius:14px;display:flex;align-items:center;justify-content:center;color:#E1306C}
.other-tool-text h3{font-size:15px;font-weight:700;color:#1a1a2e;margin:0 0 6px}
.other-tool-text p{font-size:13px;color:#666;line-height:1.5;margin:0}
.other-tool-btn{display:inline-flex;align-items:center;gap:6px;margin-top:auto;padding:11px 18px;background:linear-gradient(135deg,#833ab4,#E1306C);color:#fff;border-radius:30px;font-size:13px;font-weight:600;text-decoration:none;transition:opacity .2s ease}
.other-tool-btn:hover{opacity:.88}
@media(max-width:1100px){.other-tools-grid{grid-template-columns:repeat(3,1fr)}}
@media(max-width:700px){.other-tools-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:540px){.other-tools-grid{grid-template-columns:1fr;gap:14px}}
</style>


<script>
(function () {
  'use strict';

  var urlInput  = document.getElementById('videoUrlInput');
  var btnPaste  = document.getElementById('btnVideoPaste');
  var btnClear  = document.getElementById('btnVideoClear');
  var btnDl     = document.getElementById('btnVideoDownload');
  var btnText   = document.getElementById('btnVideoText');
  var spinner   = document.getElementById('videoSpinner');
  var resultBox = document.getElementById('videoResultBox');
  var errorMsg  = document.getElementById('videoErrorMsg');
  var errorText = document.getElementById('videoErrorText');
  var thumb     = document.getElementById('videoThumb');
  var dlLinks   = document.getElementById('videoDownloadLinks');
  var loadingEl = document.getElementById('videoLoadingMsgs');

  var MESSAGES = [
    { icon: '🎬', text: 'Finding your video...' },
    { icon: '⚡', text: 'Preparing HD file...' },
    { icon: '✅', text: 'Almost ready...' }
  ];
  var msgTimer = null, msgIndex = 0;

  function startMsgs() {
    if (!loadingEl) return;
    loadingEl.innerHTML = ''; msgIndex = 0;
    MESSAGES.forEach(function(m, i) {
      var d = document.createElement('div');
      d.className = 'loading-msg' + (i === 0 ? ' active' : '');
      d.id = 'vmsg' + i;
      d.innerHTML = '<span class="msg-dot"></span><span class="msg-dot"></span><span class="msg-dot"></span><span style="margin-left:8px">' + m.icon + ' ' + m.text + '</span>';
      loadingEl.appendChild(d);
    });
    loadingEl.classList.add('show');
    msgTimer = setInterval(function() {
      var c = document.getElementById('vmsg' + msgIndex); if(c) c.classList.remove('active');
      msgIndex = (msgIndex + 1) % MESSAGES.length;
      var n = document.getElementById('vmsg' + msgIndex); if(n) n.classList.add('active');
    }, 1200);
  }

  function stopMsgs() {
    if (msgTimer) { clearInterval(msgTimer); msgTimer = null; }
    if (loadingEl) { loadingEl.classList.remove('show'); loadingEl.innerHTML = ''; }
  }

  function toggleClear() {
    var has = urlInput && urlInput.value.trim().length > 0;
    if (btnClear) btnClear.classList[has ? 'add' : 'remove']('visible');
    if (btnPaste) btnPaste.style.display = has ? 'none' : '';
  }

  if (btnPaste) {
    btnPaste.addEventListener('click', function() {
      if (navigator.clipboard && navigator.clipboard.readText) {
        navigator.clipboard.readText().then(function(t) {
          if (t) { urlInput.value = t.trim(); toggleClear(); setTimeout(handleDownload, 300); }
        }).catch(function() { urlInput.focus(); });
      } else { urlInput.focus(); }
    });
  }

  if (btnClear) {
    btnClear.addEventListener('click', function() {
      urlInput.value = ''; toggleClear(); hideResult(); hideError(); urlInput.focus();
    });
  }

  if (urlInput) {
    urlInput.addEventListener('input', function() { toggleClear(); if (!urlInput.value) { hideResult(); hideError(); } });
    urlInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); handleDownload(); } });
  }

  if (btnDl) btnDl.addEventListener('click', handleDownload);

  function handleDownload() {
    var raw = urlInput ? urlInput.value.trim() : '';
    if (!raw) { showError('Please paste an Instagram video link first.'); return; }
    try { var _u = new URL(raw); if (_u.hostname !== 'www.instagram.com' && _u.hostname !== 'instagram.com') { showError('Please enter a valid Instagram URL.'); return; } } catch(e) { showError('Please enter a valid Instagram URL.'); return; }
    setLoading(true); hideResult(); hideError(); startMsgs();
    fetch('https://api.zoraahub.com/fetch.php', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ url: raw })
    })
    .then(function(r) { return r.json(); })
    .then(function(d) {
      stopMsgs();
      if (d.status === 'ok' && d.videos && d.videos.length > 0) renderResult(d);
      else showError(d.message || 'Could not fetch the video. Make sure the account is public and the link is correct.');
    })
    .catch(function() { stopMsgs(); showError('Network error. Please try again.'); })
    .finally(function() { setLoading(false); });
  }

  function renderResult(data) {
    if (!resultBox) return;
    if (thumb && data.thumbnail) {
      thumb.src = data.thumbnail;
      thumb.onload = function() { thumb.classList.add('loaded'); };
      thumb.onerror = function() { thumb.style.display = 'none'; };
    }
    if (dlLinks) {
      dlLinks.innerHTML = '';
      data.videos.forEach(function (v, i) {
        if (!v.url) return;
        var isHD = i === 0;
        var qualityLabel = isHD ? '1080 HD' : '720 SD';
        var btnLabel = isHD ? 'Download HD MP4' : 'Download SD MP4';

        if (isHD) {
          var overlay = document.createElement('div');
          overlay.className = 'btn-dl-overlay';
          var mainBtn = document.createElement('button');
          mainBtn.type = 'button';
          mainBtn.className = 'btn-dl-overlay-main';
          mainBtn.innerHTML = '<span>' + btnLabel + '</span>';
          var badge = document.createElement('div');
          badge.className = 'btn-dl-overlay-badge';
          badge.textContent = qualityLabel;
          mainBtn.addEventListener('click', (function (url, btn) {
            return function () { startDownload(url, btn); };
          })(v.url, mainBtn));
          overlay.appendChild(mainBtn);
          overlay.appendChild(badge);
          dlLinks.appendChild(overlay);
        } else {
          var sdBtn = document.createElement('button');
          sdBtn.type = 'button';
          sdBtn.className = 'btn-dl-sd';
          sdBtn.innerHTML = '<span>' + btnLabel + '</span>';
          sdBtn.addEventListener('click', (function (url, btn) {
            return function () { startDownload(url, btn); };
          })(v.url, sdBtn));
          dlLinks.appendChild(sdBtn);
        }
      });
    }
    resultBox.classList.add('show');
    setTimeout(function() { resultBox.scrollIntoView({ behavior: 'smooth', block: 'start' }); }, 150);
  }

function startDownload(url, clickedBtn) {
    if (typeof gtag === 'function') {
      gtag('event', 'download', {
        'content_type': 'video',
        'page_path': window.location.pathname
      });
    }

    var filename = 'video_' + Date.now() + '.mp4';

    var origHtml = '';
    if (clickedBtn) {
      origHtml = clickedBtn.innerHTML;
      clickedBtn.disabled = true;
      clickedBtn.innerHTML = '<span class="dl-dots"><span>.</span><span>.</span><span>.</span></span>';
      setTimeout(function () {
        if (clickedBtn) { clickedBtn.disabled = false; clickedBtn.innerHTML = origHtml; }
      }, 6000);
    }

    var proxyUrl = url;
    var a = document.createElement('a');
    a.href = proxyUrl;
    a.download = filename;
    a.style.display = 'none';
    document.body.appendChild(a);
    a.click();
    setTimeout(function() { if (a.parentNode) a.parentNode.removeChild(a); }, 500);
  }

  function setLoading(s) {
    if (!btnDl) return;
    btnDl.disabled = s; btnDl.classList[s ? 'add' : 'remove']('loading');
    if (btnText) btnText.textContent = s ? 'Fetching...' : 'DOWNLOAD';
    if (spinner) spinner.style.display = s ? 'block' : 'none';
  }
  function showError(m) { if (!errorMsg) return; if (errorText) errorText.textContent = m; errorMsg.classList.add('show'); }
  function hideError()  { if (errorMsg) errorMsg.classList.remove('show'); }
  function hideResult() { if (resultBox) resultBox.classList.remove('show'); }

})();
</script>

