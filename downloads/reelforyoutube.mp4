<style>
/* ══ FOOTER BASE ══ */
.site-footer{background:#0d0d14;color:rgba(255,255,255,.55);font-family:inherit}

/* ══ MAIN GRID ══ */
.footer-main{padding:52px 0 40px;border-top:1px solid rgba(255,255,255,.07)}
.footer-grid{display:grid;grid-template-columns:1.8fr 1fr 1fr;gap:40px 48px;align-items:start}

/* ══ BRAND COL ══ */
.footer-logo{display:inline-flex;text-decoration:none;margin-bottom:14px}
.footer-tagline{font-size:13px;line-height:1.65;color:rgba(255,255,255,.38);margin:0 0 20px;max-width:280px}
.footer-tiktok-badge{display:inline-flex;align-items:center;gap:7px;padding:8px 16px;border-radius:30px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.55);font-size:12px;font-weight:500;text-decoration:none;transition:all .2s ease;white-space:nowrap}
.footer-tiktok-badge:hover{border-color:rgba(255,255,255,.25);color:#fff;background:rgba(255,255,255,.08)}

/* ══ NAV COLS ══ */
.footer-col-title{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.3);margin:0 0 16px}
.footer-nav-list{list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:2px}
.footer-nav-link{display:inline-flex;align-items:center;gap:8px;padding:6px 0;font-size:13.5px;color:rgba(255,255,255,.55);text-decoration:none;transition:color .18s ease;border-bottom:none}
.footer-nav-link svg{opacity:.5;flex-shrink:0;transition:opacity .18s ease}
.footer-nav-link:hover{color:#fff}
.footer-nav-link:hover svg{opacity:1}

/* ══ ACCENT LINE on hover ══ */
.footer-nav-col .footer-nav-link{position:relative}
.footer-nav-col .footer-nav-link::after{content:'';position:absolute;left:0;bottom:-1px;width:0;height:1px;background:linear-gradient(90deg,#833ab4,#E1306C);transition:width .22s ease}
.footer-nav-col .footer-nav-link:hover::after{width:100%}

/* ══ BOTTOM BAR ══ */
.footer-bottom{border-top:1px solid rgba(255,255,255,.06);padding:16px 0}
.footer-bottom-inner{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap}
.footer-copy{margin:0;font-size:12px;color:rgba(255,255,255,.28)}
.footer-disclaimer{margin:0;font-size:11px;color:rgba(255,255,255,.18)}

